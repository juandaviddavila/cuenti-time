# pnpm configuration for Next.js
# Hoist all packages to node_modules root — required by Next.js SWC and some Radix UI packages
shamefully-hoist=true

# Avoid issues with optional peer dependencies
strict-peer-dependencies=false
auto-install-peers=true

# Seguridad: versiones exactas (sin ^/~) al hacer pnpm add
save-exact=true
