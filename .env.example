DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/faceaccess_saas"
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('base64url'))"
JWT_SECRET="GENERA_CON_CRYPTO_RANDOMBYTES_64_BASE64URL"
JWT_REFRESH_SECRET="GENERA_CON_CRYPTO_RANDOMBYTES_64_BASE64URL_DIFERENTE"
NEXT_PUBLIC_APP_URL="http://localhost:7578"
NEXT_PUBLIC_APP_NAME="cuenti time"
# Emails autorizados para la consola SaaS, separados por coma.
# Esta lista es la única fuente del acceso SAAS_SUPER_ADMIN.
SUPER_ADMIN_EMAILS="superadmin@cuenti.com"
# URL pública del MCP RRHH (Cloudflare → origen Streamable HTTP). Ej. https://mcp-time.cuenti.co/mcp
NEXT_PUBLIC_MCP_URL="http://localhost:7578/mcp"
# Upstream interno del proceso hr-mcp-server
MCP_UPSTREAM_URL="http://127.0.0.1:4101"
# Issuer OAuth público (mismo origen que la app / túnel / Cloudflare)
MCP_PUBLIC_URL="http://localhost:7578"
# Solo local http sin túnel: MCP_DANGEROUSLY_ALLOW_INSECURE_ISSUER_URL=true

# OpenRouter — SOLO servidor (liveness facial). NUNCA uses NEXT_PUBLIC_ aquí.
OPENROUTER_API_KEY="sk-or-v1-XXXXXXXX"

# Wompi Colombia (legacy / opcional)
NEXT_PUBLIC_WOMPI_PUBLIC_KEY="pub_test_XXXXXXXXXXXXXXXX"
WOMPI_PUBLIC_KEY="pub_test_XXXXXXXXXXXXXXXX"
WOMPI_INTEGRITY_SECRET="test_integrity_XXXXXXXXXXXXXXXX"
WOMPI_EVENTS_SECRET="test_events_XXXXXXXXXXXXXXXX"

# Cuenti Pay (suscripciones)
CUENTI_PAY_ENABLED=false
CUENTI_PAY_AUTH_TOKEN=""
CUENTI_PAY_API_URL="https://api.cuenti.co/jServerj4ErpPro/api/token/grabarDocumentoSimple"
CUENTI_PAY_VOID_API_URL="https://api.cuenti.co/jServerj4ErpPro/com/j4ErpPro/server/transacion/anularTransacion"
CUENTI_PAY_EMPRESA_ID="2"
CUENTI_PAY_EMPLEADO_ID="1"
CUENTI_PAY_GTM="GMT-0500"
# Recomendado para el webhook público:
# BILLING_WEBHOOK_SECRET="GENERA_CON_CRYPTO_RANDOMBYTES_32_HEX"

# Cron de reintentos de webhooks outbound (Authorization: Bearer …)
CRON_SECRET="GENERA_CON_CRYPTO_RANDOMBYTES_32_HEX"

# Opcional: clave para recuperar secretos de API tokens (si falta, usa JWT_SECRET)
# API_TOKEN_ENCRYPTION_KEY="GENERA_CON_CRYPTO_RANDOMBYTES_32_HEX"
